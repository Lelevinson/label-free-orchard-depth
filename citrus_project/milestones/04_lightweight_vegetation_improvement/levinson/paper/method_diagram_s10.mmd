%% Snapshot 10 method diagram (rebuilt from the Snapshot 07 draw.io layout).
%% S07 parts retained verbatim; the orange "EMA In-Domain Self-Teacher" block is the
%% Snapshot 10 addition. Render at https://mermaid.live or import into draw.io
%% (Arrange > Insert > Advanced > Mermaid).
flowchart TB
    RGB["RGB Temporal Frames"]

    subgraph OBJ["Snapshot 10 Training Objective"]
      direction LR

      subgraph TGS["Teacher-Guided Structure Regularization (S07)"]
        direction TB
        FT["Frozen Original<br/>Lite-Mono Teacher"]
        BR["Boundary Reliability<br/>(RGB Edges + Teacher Edges)"]
        BWL["Boundary-Weighted<br/>Teacher Structure Loss"]
        FT -->|Teacher's Depth| BR
        BR -.->|reweights| BWL
        FT --> BWL
      end

      subgraph BASE["Base Self-Supervised (S07)"]
        direction TB
        STU["Lite-Mono Student<br/>(DepthNet + PoseNet)"]
        VR["View Reconstruction<br/>(with Camera Intrinsics)"]
        PS["Photometric +<br/>Smoothness Loss"]
        STU --> VR --> PS
      end

      subgraph SKY["RGB Sky/Far Prior (S07)"]
        direction TB
        SC["Sky/Far Confidence"]
        SOL["Sky/Far Ordinal Loss"]
        SC --> SOL
      end

      subgraph EMA["EMA In-Domain Self-Teacher (Snapshot 10 - NEW)"]
        direction TB
        ET["EMA Self-Teacher<br/>(slow in-domain copy of Student)"]
        GATE["Reliability Gates<br/>(DC flip-consistency and<br/>GC min-reprojection)"]
        EDL["EMA Self-Distillation Loss<br/>(scale-invariant SI-log +<br/>structure anchor)"]
        ET -->|Teacher's Depth - target| EDL
        GATE -.->|reliable-pixel mask| EDL
      end
    end

    %% RGB feeds every perception module (S07 + the new EMA teacher)
    RGB --> FT
    RGB --> BR
    RGB --> STU
    RGB --> SC
    RGB --> ET

    %% Student's depth used by the side losses
    STU -.->|Student's Depth| BWL
    STU -.->|Student's Depth| SOL
    STU -.->|Student's Depth| EDL
    STU -.->|predictions / reprojection + flip| GATE
    STU ==>|EMA weight update| ET

    %% All losses combine into the objective
    BWL -.-> TTO["Total Training Objective"]
    PS  -.-> TTO
    SOL -.-> TTO
    EDL -.-> TTO

    TTO --> UPD["Update Student Only"]
    UPD --> INF["Training-only guidance.<br/>Inference: RGB -> Student DepthNet -> Depth"]

    %% ---- styling to match the original colors ----
    classDef teacher fill:#bfe3e0,stroke:#3f9b94,color:#000;
    classDef reliab  fill:#e6d6f2,stroke:#9b6fc1,color:#000;
    classDef loss    fill:#f7c9c9,stroke:#cc6666,color:#000;
    classDef base    fill:#eef3fb,stroke:#9bb6d9,color:#000;
    classDef green   fill:#cdeccd,stroke:#6aa66a,color:#000;
    classDef newnode fill:#fff1d6,stroke:#e0922f,color:#000;
    classDef newloss fill:#ffd9b0,stroke:#e0922f,color:#000;
    classDef plain   fill:#ededed,stroke:#888888,color:#000;

    class FT teacher;
    class BR reliab;
    class BWL loss;
    class STU,VR,PS base;
    class SC,SOL green;
    class ET,GATE newnode;
    class EDL newloss;
    class RGB,TTO,UPD,INF plain;

    style OBJ  fill:#fdf3d0,stroke:#d9b54a,color:#000;
    style TGS  fill:#dbe7f7,stroke:#6f9bd1,color:#000;
    style BASE fill:#dbe7f7,stroke:#6f9bd1,color:#000;
    style SKY  fill:#dbe7f7,stroke:#6f9bd1,color:#000;
    style EMA  fill:#ffe8c2,stroke:#e0922f,color:#000;
