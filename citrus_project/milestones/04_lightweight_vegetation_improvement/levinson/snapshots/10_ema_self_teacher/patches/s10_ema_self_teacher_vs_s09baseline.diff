+    def update_ema(self):
+        """Update the EMA self-teacher: pt <- m*pt + (1-m)*ps over params + float buffers."""
+        m = self.opt.ema_decay
+        if self.opt.ema_decay_final != self.opt.ema_decay:
+            denom = max(1, self.opt.ema_start_step + self.opt.ema_distill_warmup_steps)
+            prog = min(1.0, float(self.step + 1) / float(denom))
+            m = self.opt.ema_decay + (self.opt.ema_decay_final - self.opt.ema_decay) * prog
+        with torch.no_grad():
+            for name in self.ema_models:
+                student, ema = self.models[name], self.ema_models[name]
+                for ps, pt in zip(student.parameters(), ema.parameters()):
+                    pt.mul_(m).add_(ps.detach(), alpha=1.0 - m)
+                for bs, bt in zip(student.buffers(), ema.buffers()):
+                    if bt.is_floating_point():
+                        bt.mul_(m).add_(bs.detach(), alpha=1.0 - m)
+                    else:
+                        bt.copy_(bs)
+
+    def compute_ema_distill_loss(self, inputs, outputs, losses):
+        """Snapshot 10: EMA in-domain self-teacher distillation, gated by two INDEPENDENT
+        reliability filters (GC geometric min-reprojection + DC flip-consistency).
+        Training-only, label-free. Inference unchanged. See
+        snapshots/10_ema_self_teacher/DESIGN_NOTE.md.
+        """
+        if self.step < self.opt.ema_start_step or not self.ema_models:
+            return outputs[("disp", 0)].new_tensor(0.0)
+
+        color = inputs[("color", 0, 0)]
+        hw = color.shape[-2:]
+
+        def to_hw(t):
+            if t.shape[-2:] != hw:
+                return F.interpolate(t, hw, mode="bilinear", align_corners=False)
+            return t
+
+        # Student disparity (grad on) and EMA teacher disparity on CLEAN target (no grad).
+        s_disp = to_hw(outputs[("disp", 0)])
+        with torch.no_grad():
+            t_disp = to_hw(
+                self.ema_models["depth"](self.ema_models["encoder"](color))[("disp", 0)]).detach()
+
+        # GC filter (free): reuse the post-automask min-reprojection error.
+        pe = to_hw(outputs[("photo_error", 0)].detach())
+        delta_g = (self.opt.ema_gc_tau * pe.mean()
+                   if self.opt.ema_filter_adaptive else pe.new_tensor(self.opt.ema_gc_delta))
+        m_g = (pe < delta_g).float()
+
+        # DC filter: EMA teacher self-consistency under horizontal flip, in RAW disparity space.
+        with torch.no_grad():
+            flip_disp = to_hw(self.ema_models["depth"](
+                self.ema_models["encoder"](torch.flip(color, dims=[3])))[("disp", 0)])
+            t_disp_flip = torch.flip(flip_disp, dims=[3]).detach()
+        dc = torch.abs(t_disp - t_disp_flip)
+        delta_d = (self.opt.ema_dc_tau * dc.mean()
+                   if self.opt.ema_filter_adaptive else dc.new_tensor(self.opt.ema_dc_delta))
+        m_d = (dc < delta_d).float()
+
+        M = (m_g * m_d).detach()
+        keep = M.mean()
+        canopy = M[:, :, int(0.4 * M.shape[-2]):, :]
+        keep_canopy = canopy.mean()
+
+        # Warmup ramp from ema_start_step; starvation guard.
+        denom = max(1, self.opt.ema_distill_warmup_steps)
+        prog = min(1.0, max(0.0, float(self.step + 1 - self.opt.ema_start_step) / float(denom)))
+        gamma = self.opt.ema_distill_weight * prog
+        if float(keep) < self.opt.ema_min_keep_ratio:
+            gamma = 0.0
+
+        # Term A: scale-and-shift-aware metric log-depth distillation (the abs_rel mover).
+        _, z_s = disp_to_depth(s_disp, self.opt.min_depth, self.opt.max_depth)
+        _, z_t = disp_to_depth(t_disp, self.opt.min_depth, self.opt.max_depth)
+        r = torch.log(z_s.clamp_min(1e-6)) - torch.log(z_t.clamp_min(1e-6)).detach()
+        r_bar = (M * r).sum() / (M.sum() + 1e-6)
+        l_si = (M * self.charbonnier(r - r_bar)).sum() / (M.sum() + 1e-6)
+
+        # Term B: normalized-log structure anchor (protects relative shape / a1).
+        s_struct = self.normalized_log_inverse_from_disp(s_disp)
+        t_struct = self.normalized_log_inverse_from_disp(t_disp).detach()
+        l_struct = self.weighted_mean(self.charbonnier(s_struct - t_struct), M)
+
+        l_dist = l_si + self.opt.ema_struct_weight * l_struct
+        total = gamma * l_dist
+
+        losses["ema_distill/l_si"] = l_si.detach()
+        losses["ema_distill/l_struct"] = l_struct.detach()
+        losses["ema_distill/keep_ratio"] = keep.detach()
+        losses["ema_distill/keep_ratio_canopy"] = keep_canopy.detach()
+        losses["ema_distill/gamma"] = torch.tensor(gamma, device=self.device)
+        losses["ema_distill/total"] = total.detach()
+        return total
